# 🔐 Flame Japanese Hibachi (FJH) - Environment Variables Template
# Copy this file to .env.local and fill in your values.

# -----------------------------------------------------------------------------
# 🗄️ Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string (Prisma format)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://postgres:password@localhost:5432/fjh_db?schema=public"

# -----------------------------------------------------------------------------
# 🔐 Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
# The base URL of your application
NEXTAUTH_URL="http://localhost:3000"

# Generate a secret using: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"

# Default Admin Email (for initial setup/seeding)
NEXTAUTH_ADMIN_EMAIL="admin@fjh-hibachi.com"

# OAuth Providers (Uncomment and fill to enable)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# 🌐 API Configuration
# -----------------------------------------------------------------------------
# Public API base URL (accessible by both client and server)
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000/api"

# -----------------------------------------------------------------------------
# 💳 Payment Processing (Stripe)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# 📧 Email Service (SMTP / Resend / Mailtrap)
# -----------------------------------------------------------------------------
EMAIL_FROM="no-reply@fjh-hibachi.com"
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=587
SMTP_USER="your-smtp-user"
SMTP_PASSWORD="your-smtp-password"

# -----------------------------------------------------------------------------
# 🗺️ External Integrations
# -----------------------------------------------------------------------------
# DoorDash Integration
DOORDASH_DEVELOPER_ID=""
DOORDASH_KEY_ID=""
DOORDASH_SIGNING_SECRET=""

# -----------------------------------------------------------------------------
# ⚙️ Application Settings
# -----------------------------------------------------------------------------
# Supported values: development, test, production
NODE_ENV="development"

# App Logging Level
LOG_LEVEL="debug"
